9:["$","div",null,{"className":"card overflow-hidden shadow rounded-4 border-0 mb-5","children":["$","div",null,{"className":"card-body p-0","children":["$","div",null,{"className":"d-flex align-items-center project-card-flex","children":[["$","div",null,{"className":"p-5 project-text","children":[["$","h4",null,{"className":"fw-bolder","children":"Voice Switch Based on Hierarchical KWS"}],["$","p",null,{"className":"fw-bolder","children":"專案說明"}],["$","ul",null,{"className":"font-color-555","children":["$","li",null,{"children":"「使聲控裝置以及低的功耗運作」讓此裝置結合其他產品時可以很省電，因此讓系統平時處於功耗極低的睡眠狀態，並透過睡眠、人聲判斷、關鍵字辨識漸進式開啟來降低功耗；3 個階段由省電到耗電"}]}],["$","p",null,{"className":"fw-bolder","children":"負責項目"}],["$","ul",null,{"className":"font-color-555","children":[["$","li",null,{"children":"透過訓練 DNN 達成人聲語音識別（VAD）"}],["$","li",null,{"children":"先辨識 VAD 再辨識關鍵字，同樣使用 DNN 達成 Key Keyword Spotting（KWS）"}],["$","li",null,{"children":"語音辨識訓練量大相當耗電，因此使用 Apollo 3 Blue 板達到低功耗"}],["$","li",null,{"children":"接手大學專題生專題，並測試、維護、交接說明文件、開發"}]]}]]}],["$","img",null,{"className":"img-fluid project-img","src":"/assets/VAD_KWS.png","alt":"VAD KWS"}]]}]}]}]
